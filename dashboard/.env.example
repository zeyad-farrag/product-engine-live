# ─── Required ─────────────────────────────────────────────────────────────────
# GitHub personal access token (repo scope) — omit to run in demo mode
GITHUB_TOKEN=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Express server port (default: 5000)
PORT=5000

# MySQL API port (default: 8001, used by docker-compose only)
MYSQL_API_PORT=8001

# Node environment
NODE_ENV=production
